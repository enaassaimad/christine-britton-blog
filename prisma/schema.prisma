// Prisma schema for an editorial blog / CMS with AdSense support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("ADMIN") // ADMIN | EDITOR
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?  // accent color (hex)
  icon        String?  // lucide icon name
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]
}

model Post {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String    // markdown / html
  coverImage    String?
  coverAlt      String?
  status        String    @default("DRAFT") // DRAFT | PUBLISHED | SCHEDULED
  featured      Boolean   @default(false)
  trending      Boolean   @default(false)
  readMinutes   Int       @default(5)
  tags          String?   // comma separated
  metaTitle     String?
  metaDescription String?
  // AdSense control
  showAds       Boolean   @default(true)
  // Affiliate links: JSON-encoded array of {id, title, url, description, image, price, label}
  affiliateLinks String?
  views         Int       @default(0)
  likes         Int       @default(0)

  authorId      String
  author        User      @relation(fields: [authorId], references: [id])

  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])

  comments      Comment[]

  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String
  email     String
  content   String
  status    String   @default("PENDING") // PENDING | APPROVED | SPAM
  createdAt DateTime @default(now())

  @@index([postId, status])
}

model SiteSetting {
  id              String   @id @default("singleton")
  siteName        String   @default("Lumen Journal")
  tagline         String   @default("Stories, ideas & thoughtful living")
  description     String?
  logoText        String?
  logoUrl         String?
  faviconUrl      String?
  // Branding
  primaryColor    String   @default("#b45309") // amber-700
  accentColor     String   @default("#9a3412") // orange-800
  // Contact / social
  email           String?
  phone           String?
  location        String?
  twitter         String?
  instagram       String?
  facebook        String?
  linkedin        String?
  pinterest       String?
  youtube         String?
  // About
  aboutTitle      String?
  aboutContent    String?
  aboutImage      String?
  // AdSense
  adsenseClient   String?  // ca-pub-XXXXXXXXXXXXXXXX
  adsenseSlotHeader    String?
  adsenseSlotInArticle String?
  adsenseSlotSidebar   String?
  adsenseSlotFooter    String?
  adsenseSlotInContent String?
  adsEnabled      Boolean  @default(true)
  // Newsletter
  newsletterTitle String?
  newsletterText  String?
  // Footer
  footerText      String?
  // AI post generator
  aiApiKey        String?
  aiModel         String?  @default("glm-5.2")
  updatedAt       DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  caption   String?
  width     Int?
  height    Int?
  type      String   @default("image") // image | video
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   // markdown
  excerpt     String?
  type        String   @default("LEGAL") // LEGAL | CUSTOM
  showInFooter Boolean @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DigitalProduct {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  description   String   // markdown
  coverImage    String?
  coverAlt      String?
  price         String   // e.g. "$19.99" or "Free"
  originalPrice String?  // for showing discounts
  buyUrl        String   // external checkout (Gumroad, Stripe, etc.)
  buyLabel      String   @default("Buy now")
  category      String?  // ebook, course, template, bundle
  featured      Boolean  @default(false)
  tags          String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
